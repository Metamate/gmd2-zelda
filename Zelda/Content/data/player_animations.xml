<?xml version="1.0" encoding="utf-8" ?>
<!--
  Player animation definitions, grouped by sprite sheet.
  frameWidth/frameHeight: pixel size of each frame in the sheet
  frames:   0-based frame indices, comma-separated
  interval: seconds per frame
  loop:     true (default) or false
-->
<PlayerAnimations>

  <Atlas image="images/character_walk" frameWidth="16" frameHeight="32">
    <Animation name="walk-down"  frames="0,1,2,3"     interval="0.15"  />
    <Animation name="walk-right" frames="4,5,6,7"     interval="0.15"  />
    <Animation name="walk-up"    frames="8,9,10,11"   interval="0.15"  />
    <Animation name="walk-left"  frames="12,13,14,15" interval="0.155" />
    <Animation name="idle-down"  frames="0"           interval="0.15"  />
    <Animation name="idle-right" frames="4"           interval="0.15"  />
    <Animation name="idle-up"    frames="8"           interval="0.15"  />
    <Animation name="idle-left"  frames="12"          interval="0.15"  />
  </Atlas>

  <Atlas image="images/character_swing_sword" frameWidth="32" frameHeight="32">
    <Animation name="sword-down"  frames="0,1,2,3"     interval="0.05" loop="false" />
    <Animation name="sword-up"    frames="4,5,6,7"     interval="0.05" loop="false" />
    <Animation name="sword-right" frames="8,9,10,11"   interval="0.05" loop="false" />
    <Animation name="sword-left"  frames="12,13,14,15" interval="0.05" loop="false" />
  </Atlas>

</PlayerAnimations>
